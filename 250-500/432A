#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;
    int k; cin >> k;

    int cnt = 0;
    for (int i = 0; i < n; ++i) {
        int a; cin >> a;
        if (a + k <= 5)
            ++cnt;
    }

    cout << cnt / 3 << "\n";

    return 0;
}
