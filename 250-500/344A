#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;
    int cnt = 1;

    string prev; 
    cin >> prev;
    for (int i = 1; i < n; ++i) {
        string curr;
        cin >> curr;

        if (prev != curr)
            ++cnt;
        prev = curr;
    }

    cout << cnt << "\n";

    return 0;
}
