#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;

    unordered_map<string, int> umap = {
        {"Tetrahedron", 4},
        {"Cube", 6},
        {"Octahedron", 8},
        {"Dodecahedron", 12},
        {"Icosahedron", 20},
    };

    int cnt = 0;
    for (int i = 0; i < n; ++i) {
        string s; cin >> s;
        cnt += umap[s];
    }
    cout << cnt << "\n";
    
    return 0;
}
