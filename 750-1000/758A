#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;
    int arr[n];

    int maxi = 0;

    for (int i = 0; i < n; ++i) {
        cin >> arr[i];
        maxi = max(maxi, arr[i]);
    }

    int count = 0;
    for (int i = 0; i < n; ++i)
        count += maxi - arr[i];
    cout << count << "\n";

    return 0;
}
