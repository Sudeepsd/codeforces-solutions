#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;

    if (n % 4 != 0) {
        cout << "NO\n";
        return;
    }

    cout << "YES\n";

    int total = 0;
    for (int i = 2; i <= n; i += 2) {
        cout << i << " ";
        total += i;
    }

    for (int i = 1; i < n - 1; i += 2) {
        total -= i;
        cout << i << " ";
    }
    cout << total << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
