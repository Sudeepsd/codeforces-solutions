#include <bits/stdc++.h>
using namespace std;

void solve() {
    string s;
    cin >> s;

    cout << s[0];

    for (int i = 1; i < s.length(); i += 2)
        cout << s[i];
    cout << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
