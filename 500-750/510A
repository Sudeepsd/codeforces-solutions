#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int m, n;
    cin >> m >> n;

    int last = true;
    for (int i = 0; i < m; ++i) {
        if (i % 2 == 0) {
            for (int j = 0; j < n; ++j)
                cout << "#";
            cout << "\n";
        } else {
            if (!last)
                cout << "#";
            for (int j = 0; j < n - 1; ++j)
                cout << ".";
            if (last)
                cout << "#";
            last = !last;
            cout << "\n";
        }
    }

    return 0;
}
