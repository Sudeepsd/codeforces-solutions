#include <bits/stdc++.h>
using namespace std;

void solve() {
    int m, n, x, y;
    cin >> m >> n >> x >> y;

    int ans = -1;
    for (int i = 1; i <= m; ++i) {
        for (int j = 1; j <= n; ++j) {
            char ch; cin >> ch;
            if (ch == 'B') {
                if (x == i && y == j) {
                    ans = 0;
                } else if (ans != 0 && (x == i || y == j)) {
                    ans = 1;
                } else if (ans == -1) {
                    ans = 2;
                }
            }
        }
    }

    cout << ans << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
