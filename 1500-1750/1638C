#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;

    int val = 0;
    int cnt = 0;
    for (int i = 1; i <= n; ++i) {
        int a; cin >> a;
        val = max(val, a);
        if (i == val)
            ++cnt;
    }
    cout << cnt << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
