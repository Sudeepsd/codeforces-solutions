#include <bits/stdc++.h>
using namespace std;

void solve() {
    long long n, a, b;
    cin >> n >> a >> b;

    int x = a & 1;
    for (int i = 0; i < n; ++i) {
        long long p; cin >> p;
        x ^= (p & 1);
    }

    if (b % 2 == x)
        cout << "Alice\n";
    else
        cout << "Bob\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
