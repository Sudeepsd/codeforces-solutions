#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;

    int arr[n + 1];
    for (int i = 1; i <= n; ++i)
        cin >> arr[i];

    int r = 0;
    for (int i = 1; i <= n; ++i) {
        if (i != arr[i]) {
            r = i;
            break;
        }
        cout << i << " ";
    }

    if (r == 0) {
        cout << "\n";
        return;
    }

    int l = 0;
    for (int i = r; i <= n; ++i) {
        if (arr[i] == r) {
            l = i;
            break;
        }
    }

    for (int i = l; i >= r; --i) {
        cout << arr[i] << " ";
    }
    for (int i = l + 1; i <= n; ++i) {
        cout << arr[i] << " ";
    }
    cout << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
