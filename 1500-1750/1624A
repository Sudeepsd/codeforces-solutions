#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;
    int maxi = INT_MIN, mini = INT_MAX;

    for (int i = 0; i < n; ++i) {
        int a; cin >> a;
        maxi = max(maxi, a);
        mini = min(mini, a);
    }

    cout << maxi - mini << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
