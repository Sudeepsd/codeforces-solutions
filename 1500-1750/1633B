#include <bits/stdc++.h>
using namespace std;

void solve() {
    string s;
    cin >> s;

    int ones = 0, zeros = 0;
    for (int i = 0; i < s.length(); ++i) {
        if (s[i] == '0')
            ++zeros;
        else 
            ++ones;
    }

    if (zeros == ones)
        cout << zeros - 1 << "\n";
    else
        cout << min(zeros, ones) << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
