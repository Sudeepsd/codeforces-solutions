#include <bits/stdc++.h>
using namespace std;

void solve() {
    int m, n, a, b, p, q;
    cin >> m >> n >> a >> b >> p >> q;

    int ans = min(a <= p ? p - a : (m - a) + (m - p), b <= q ? q - b : n - b + n - q);
    cout << ans << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
