#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;
    string s = to_string(n);

    int cnt = 9 * (s.length() - 1);
    
    int i;
    for (i = 1; i < s.length(); ++i) {
        if (s[0] != s[i])
            break;
    }

    if (i == s.length() || s[0] < s[i])
        cnt += s[0] - '0';
    else
        cnt += s[0] - '0' - 1;

    cout << cnt << "\n";
    
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
