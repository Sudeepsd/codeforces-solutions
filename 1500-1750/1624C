#include <bits/stdc++.h>
using namespace std;

void solve() {
    int n; cin >> n;

    vector<bool> arr(n + 1, false);

    for (int i = 0; i < n; ++i) {
        int a; cin >> a;
        while (a != 0 && (a > n || arr[a])) a /= 2;
        arr[a] = true;
    }
    
    if (arr[0])
        cout << "NO";
    else
        cout << "YES";

    cout << "\n";
}

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int T; cin >> T;
    while (T--) {
        solve();
    }

    return 0;
}
