#include <bits/stdc++.h>
using namespace std;

int main() {
    ios_base::sync_with_stdio(false);
    cin.tie(NULL);

    int n; cin >> n;
    vector<vector<int>> arr(3);

    for (int i = 1; i <= n; ++i) {
        int a; cin >> a;
        arr[a - 1].push_back(i);
    }

    int teams = min({arr[0].size(), arr[1].size(), arr[2].size()});
    cout << teams << "\n";

    for (int i = 0; i < teams; ++i) {
        cout << arr[0][i] << " " << arr[1][i] << " " << arr[2][i] << "\n";
    }

    return 0;
}
